# Server port (default: 5000)
PORT=5000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/officecrm

# JWT secret for auth tokens
JWT_SECRET=change-me-in-production

# Optional: Brevo transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=OfficeFlow CRM

# WhatsApp notifications via OpenWA gateway (https://docs.open-wa.org/)
# Run OpenWA separately (default port 2785), then fill key + session id.
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=http://localhost:2785
WHATSAPP_API_KEY=
WHATSAPP_SESSION_ID=

# OpenWA inbound webhook signature secret (must match the secret set when registering the webhook)
OPENWA_WEBHOOK_SECRET=

# Outbound send throttling (anti-ban): min delay + random jitter between queued sends.
# WHATSAPP_SEND_MIN_DELAY_MS=3000
# WHATSAPP_SEND_JITTER_MS=2000

# AI provider for WhatsApp RAG task bot (swappable via AI_PROVIDER)
# Supported: gemini | azure (azure-openai)
AI_PROVIDER=gemini

# Gemini (chat when AI_PROVIDER=gemini; embeddings always used by azure provider for RAG)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# Azure OpenAI (chat + tools when AI_PROVIDER=azure|azure-openai)
# Embeddings still use Gemini so existing vector(768) task_embeddings stay valid.
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name
